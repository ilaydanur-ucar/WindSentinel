# ── RabbitMQ ──
RABBITMQ_USER=your_rabbitmq_username
RABBITMQ_PASS=your_rabbitmq_password_min_16_chars

# ── PostgreSQL ──
POSTGRES_DB=windsentinel
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password_min_16_chars
POSTGRES_PORT=5434

# ── API Gateway ──
JWT_SECRET=generate_with_openssl_rand_hex_32_or_node_crypto
API_PORT=8000

# ── RabbitMQ Connection ──
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672

# ── Database Connection ──
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_URL_LOCAL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Generate strong values ──
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# openssl rand -hex 32
