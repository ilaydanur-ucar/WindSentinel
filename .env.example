# ── RabbitMQ ──
RABBITMQ_USER=admin
RABBITMQ_PASS=CHANGE_ME_STRONG_PASSWORD
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── PostgreSQL ──
POSTGRES_DB=windsentinel
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5434

# ── API Gateway ──
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
API_PORT=8000

# ── Notification Service ──
NOTIFICATION_PORT=8003

# ── Connection Strings (container icinde kullanilir) ──
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Localhost erisimi (gelistirme icin) ──
DATABASE_URL_LOCAL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
